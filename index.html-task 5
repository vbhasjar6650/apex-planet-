<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ShopEase | Capstone Project</title>

    <link rel="stylesheet" href="style.css">

    <!-- Font Awesome -->
    <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>

<!-- ================= NAVBAR ================= -->

<header>

<nav class="navbar">

<div class="logo">
<i class="fa-solid fa-cart-shopping"></i>
<span>ShopEase</span>
</div>

<ul class="nav-links">

<li><a href="#home">Home</a></li>
<li><a href="#products">Products</a></li>
<li><a href="#about">About</a></li>
<li><a href="#contact">Contact</a></li>

</ul>

<div class="nav-icons">

<input
type="text"
id="search"
placeholder="Search products">

<button id="darkMode">
<i class="fa-solid fa-moon"></i>
</button>

<div class="cart-icon">

<i class="fa-solid fa-cart-shopping"></i>

<span id="cart-count">
0
</span>

</div>

</div>

</nav>

</header>

<!-- ================= HERO ================= -->

<section class="hero" id="home">

<div class="hero-text">

<h1>
Modern Shopping Experience
</h1>

<p>

Find the latest fashion,
electronics,
accessories,
and more.

</p>

<a href="#products">

<button>

Shop Now

</button>

</a>

</div>

<div class="hero-image">

<img
src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=700"
loading="lazy"
alt="Hero">

</div>

</section>

<!-- ================= CATEGORIES ================= -->

<section class="categories">

<h2>

Categories

</h2>

<div class="category-buttons">

<button class="filter-btn" data-category="All">
All
</button>

<button class="filter-btn" data-category="Electronics">
Electronics
</button>

<button class="filter-btn" data-category="Fashion">
Fashion
</button>

<button class="filter-btn" data-category="Shoes">
Shoes
</button>

<button class="filter-btn" data-category="Accessories">
Accessories
</button>

</div>

</section>

<!-- ================= PRODUCTS ================= -->

<section id="products">

<h2>

Featured Products

</h2>

<div id="product-container" class="products">

<!-- JavaScript Products -->

</div>

</section>

<!-- ================= CART ================= -->

<section class="cart">

<h2>

Shopping Cart

</h2>

<div id="cart-items">

<p>

Cart is Empty

</p>

</div>

<div class="cart-total">

<h3>

Total :
₹<span id="total">
0
</span>

</h3>

<button id="checkout">

Checkout

</button>

</div>

</section>

<!-- ================= ABOUT ================= -->

<section id="about" class="about">

<h2>

About Us

</h2>

<p>

ShopEase is a modern responsive
e-commerce website built using
HTML,
CSS and JavaScript.

This project demonstrates
DOM Manipulation,
Responsive Design,
Shopping Cart,
Dark Mode,
Search,
Filter,
and Local Storage.

</p>

</section>

<!-- ================= CONTACT ================= -->

<section id="contact">

<h2>

Contact Us

</h2>

<form id="contactForm">

<input
type="text"
placeholder="Your Name"
required>

<input
type="email"
placeholder="Email"
required>

<textarea
placeholder="Message"
required></textarea>

<button type="submit">

Send Message

</button>

</form>

</section>

<!-- ================= FOOTER ================= -->

<footer>

<p>

© 2026 ShopEase.
All Rights Reserved.

</p>

</footer>

<script src="script.js"></script>

</body>
</html>
